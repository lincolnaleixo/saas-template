# ================================================
# Project Configuration
# ================================================
# Copy this file to .env.local for development
# or .env.production for production deployments
# ================================================

# Project Identification
PROJECT_NAME=myapp
DOMAIN_NAME=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Environment
NODE_ENV=development

# ================================================
# Port Configuration
# ================================================
# All ports are configurable to support multiple
# deployments on the same server

# Application Ports
API_PORT=8000
WORKER_PORT=8002
FRONTEND_PORT=4001

# Database Ports
DB_PORT=5432
PGADMIN_PORT=5050

# Redis Ports
REDIS_PORT=6379
REDIS_INSIGHT_PORT=8001

# Development Tool Ports
MAILDEV_PORT=1080
MAILDEV_SMTP_PORT=1025

# Nginx Ports (Production)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ================================================
# Database Configuration
# ================================================
# PostgreSQL Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=${PROJECT_NAME}

# Database URL (auto-generated, do not modify)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${DB_PORT}/${POSTGRES_DB}

# Production Database (if different)
# PRODUCTION_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# STAGING_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ================================================
# Redis Configuration
# ================================================
REDIS_URL=redis://localhost:${REDIS_PORT}
REDIS_MAX_MEMORY=256mb

# ================================================
# Authentication & Security
# ================================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
SESSION_COOKIE_MAX_AGE=604800000

# Google OAuth (for login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:${API_PORT}/api/auth/google/callback

# ================================================
# API Configuration
# ================================================
# API Base URL
API_BASE_URL=http://localhost:${API_PORT}

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:${FRONTEND_PORT},http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ================================================
# Worker Configuration
# ================================================
# Job Queue Settings (pg-boss)
JOB_CONCURRENCY=5
JOB_POLL_INTERVAL=1000
JOB_ARCHIVE_DAYS=30
JOB_DELETE_AFTER_DAYS=7

# ================================================
# Email Configuration
# ================================================
# Development (MailDev)
SMTP_HOST=localhost
SMTP_PORT=${MAILDEV_SMTP_PORT}
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Production (Example: SendGrid)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Email Settings
EMAIL_FROM="${PROJECT_NAME} <noreply@${DOMAIN_NAME}>"

# ================================================
# Storage Configuration
# ================================================
# File Upload Settings
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Storage Provider (local, s3)
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads

# S3 Configuration (if using S3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ================================================
# External Services
# ================================================
# AI/LLM Configuration (for git.ts and other AI features)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# Analytics (optional)
# POSTHOG_API_KEY=your-posthog-key
# POSTHOG_HOST=https://app.posthog.com

# ================================================
# Development Tools
# ================================================
# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Enable development tools (set to true to enable)
ENABLE_DEV_TOOLS=false

# ================================================
# Backup Configuration
# ================================================
# Backup Schedule (cron format)
BACKUP_CRON=0 2 * * *
MAX_BACKUPS=10
BACKUP_DIR=./backups

# ================================================
# Monitoring & Logging
# ================================================
# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Logger Configuration
LOG_TO_FILE=true                     # Enable file logging (backend) - RECOMMENDED
LOG_DIR=./logger                     # Directory for log files (backend)
LOG_MAX_SIZE=10485760               # Max log file size in bytes (10MB)
LOG_MAX_FILES=10                    # Number of log files to keep
LOG_EMOJIS=true                     # Enable emojis in console logs (dev)
LOG_COLORS=true                     # Enable colors in console logs (dev)

# Remote Logging (frontend)
REMOTE_LOG_ENDPOINT=                # Endpoint for remote logging
REMOTE_LOG_API_KEY=                 # API key for remote logging

# Sentry Error Tracking (optional)
# SENTRY_DSN=https://your-key@sentry.io/project-id

# ================================================
# Feature Flags
# ================================================
# Enable/disable features
ENABLE_REGISTRATION=true
ENABLE_OAUTH=true
ENABLE_API_DOCS=true
ENABLE_WEBSOCKETS=false

# ================================================
# Admin Dashboard Configuration
# ================================================
# Admin Dashboard Branding
ADMIN_DASHBOARD_TITLE=SaaS Admin Dashboard
ADMIN_LOGO_URL=/static/images/logo.png
ADMIN_FAVICON_URL=/static/images/favicon.ico

# Admin Dashboard Theme
ADMIN_DEFAULT_THEME=light            # light or dark
ADMIN_ALLOW_THEME_TOGGLE=true        # Allow users to change theme
ADMIN_SIDEBAR_COLLAPSED=false        # Default sidebar state

# Admin Dashboard Features
ADMIN_ENABLE_NOTIFICATIONS=true      # Enable notification system
ADMIN_ENABLE_ACTIVITY_LOGS=true      # Enable activity logging
ADMIN_ENABLE_USER_MANAGEMENT=true    # Enable user management features
ADMIN_ENABLE_SYSTEM_SETTINGS=true    # Enable system settings management

# Admin Dashboard Security
ADMIN_SESSION_TIMEOUT=3600000        # Admin session timeout (1 hour)
ADMIN_REQUIRE_2FA=false              # Require 2FA for admin users
ADMIN_MAX_LOGIN_ATTEMPTS=5           # Max login attempts before lockout

# ================================================
# Migration Settings
# ================================================
# Drizzle Configuration
DRIZZLE_MIGRATIONS_TABLE=__drizzle_migrations

# ================================================
# Production Specific
# ================================================
# SSL/TLS Configuration
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# CDN Configuration
# CDN_URL=https://cdn.example.com

# ================================================
# Notes
# ================================================
# 1. Never commit .env.local or .env.production
# 2. Keep this file updated with all variables
# 3. Use strong, unique passwords in production
# 4. Regularly rotate secrets and API keys
# 5. Set appropriate CORS origins for production