# Build stage
FROM oven/bun:1-alpine AS builder

WORKDIR /app

# Copy package files
COPY package.json ./
COPY bun.lockb* ./

# Install dependencies
RUN bun install

# Copy frontend source code and config
COPY frontend ./frontend
COPY vite.config.js ./
COPY tsconfig.json* ./

# Set build-time environment variables
ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL}

# Build the frontend for production
RUN bun run build

# Production stage - serve static files with nginx
FROM nginx:alpine

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy custom nginx config for SPA
COPY infra/nginx/frontend.conf /etc/nginx/conf.d/default.conf

# Create runtime config script
RUN echo '#!/bin/sh' > /docker-entrypoint.d/01-generate-config.sh && \
    echo 'echo "window.__RUNTIME_CONFIG__ = { VITE_API_URL: \"$VITE_API_URL\" };" > /usr/share/nginx/html/config.js' >> /docker-entrypoint.d/01-generate-config.sh && \
    chmod +x /docker-entrypoint.d/01-generate-config.sh

# Expose port 80
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]