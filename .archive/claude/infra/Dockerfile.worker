FROM oven/bun:1-alpine

WORKDIR /app

# Copy package files
COPY package.json ./
COPY bun.lockb* ./

# Install dependencies
RUN bun install

# Copy worker source code
COPY worker ./worker
# Copy backend (for shared job definitions)
COPY backend ./backend

# Run with hot reload
CMD ["bun", "run", "--watch", "worker/index.ts"]