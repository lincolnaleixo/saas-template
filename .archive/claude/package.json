{
  "name": "saas-admin-dashboard",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot backend/server.ts",
    "start": "bun run backend/server.ts",
    "worker": "bun run worker/index.ts",
    "migrate": "bun run scripts/migrate.ts",
    "seed": "bun run migrations/seeds/001_initial_data.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured - using TypeScript for error checking'",
    "test": "bun test",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^6.4.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.29.3",
    "drizzle-zod": "^0.5.1",
    "lucia": "^3.0.1",
    "pg-boss": "^9.0.3",
    "postgres": "^3.4.3",
    "redis": "^4.6.12",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.0.0",
    "drizzle-kit": "^0.20.13",
    "typescript": "^5.8.3"
  }
}