# Environment Configuration Template
# ==================================
# Copy this file to .env.local for development or .env.production for production
# Update all values marked with CHANGE_ME or replace with your actual values
# NEVER commit .env.local or .env.production to git

# Project Configuration
# ---------------------
PROJECT_NAME=myapp                    # Used for container names, database name, etc.
DOMAIN_NAME=example.com               # Your domain (use localhost for dev)
LETSENCRYPT_EMAIL=admin@example.com   # Email for SSL certificates

# Docker Compose Configuration
# ----------------------------
COMPOSE_FILE=docker-compose.yml       # Use docker-compose.prod.yml for production
COMPOSE_PATH=./infra                  # Path to infrastructure files
COMPOSE_BAKE=true                     # Enable Docker Compose Bake for performance
DEV_SERVICES="frontend api scheduler db redis"  # Services to start in dev mode

# Database Configuration
# ----------------------
DB_NAME=${PROJECT_NAME}               # Database name (defaults to project name)
DB_USER=postgres                      # PostgreSQL user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD # PostgreSQL password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${PROJECT_NAME}-db:5432/${DB_NAME}

# Redis Configuration
# -------------------
REDIS_PORT=6379                       # Redis port
REDIS_URL=redis://${PROJECT_NAME}-redis:${REDIS_PORT}

# API Configuration
# -----------------
API_PORT=8000                         # Internal API port
NEXT_PUBLIC_API_URL=http://localhost:${API_PORT}  # Frontend API URL

# Authentication (Lucia)
# ----------------------
AUTH_SECRET=CHANGE_ME_64_CHAR_SECRET  # Generate with: openssl rand -base64 48

# OAuth Providers
# ---------------
# Google OAuth Setup Instructions:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project or select an existing one
# 3. Navigate to "APIs & Services" > "Credentials"
# 4. Click "Create Credentials" > "OAuth client ID"
# 5. If prompted, configure the OAuth consent screen first:
#    - Choose "External" for user type (unless using Google Workspace)
#    - Fill in required fields (app name, support email, etc.)
#    - Add scopes: email, profile, openid
#    - Add test users if in development
# 6. For Application type, select "Web application"
# 7. Add Authorized JavaScript origins:
#    - http://localhost (for development)
#    - http://localhost:3000 (for development)
#    - https://yourdomain.com (for production)
# 8. Add Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (for development)
#    - https://yourdomain.com/api/auth/callback/google (for production)
# 9. Click "Create" and copy the Client ID and Client Secret
#
GOOGLE_CLIENT_ID=                     # Your OAuth 2.0 Client ID (looks like: xxxxx.apps.googleusercontent.com)
GOOGLE_CLIENT_SECRET=                 # Your OAuth 2.0 Client Secret (keep this secure!)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google  # Must match exactly what's in Google Console
#
# Common Issues:
# - "redirect_uri_mismatch" error: Ensure the URI matches EXACTLY (including trailing slashes)
# - "Access blocked" error: Make sure OAuth consent screen is configured
# - For production: Update all URIs to use HTTPS and your actual domain
# - For multiple environments: Create separate OAuth clients for dev/staging/prod

# Nginx Configuration
# -------------------
NGINX_HTTP_PORT=80                    # Public HTTP port
NGINX_HTTPS_PORT=443                  # Public HTTPS port

# SSL Configuration (Production)
# ------------------------------
SSL_STAGING=false                     # Set to true for Let's Encrypt staging

# Git Automation (AI Commit Messages)
# -----------------------------------
GROQ_API_KEY=                         # Get from https://console.groq.com
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile   # or qwen-qwq-32b
GROQ_TEMPERATURE=0.7
GROQ_TOP_P=0.95
GROQ_MAX_TOKENS=50000
GIT_MAX_RETRIES=3
GIT_RETRY_DELAY_MS=3000

# Backup Configuration
# --------------------
BACKUP_DIR=./backups                  # Where to store database backups
MAX_BACKUPS=10                        # Number of backups to keep

# Queue Monitoring (Bull Board)
# -----------------------------
BULL_BOARD_PORT=3001                  # Port for Bull Board UI

# Email Configuration (Optional)
# ------------------------------
SMTP_HOST=                            # SMTP server hostname
SMTP_PORT=                            # SMTP port (usually 587 or 465)
SMTP_USER=                            # SMTP username
SMTP_PASSWORD=                        # SMTP password
SMTP_FROM=                            # Default from email
SMTP_SECURE=false                     # Use TLS/SSL

# External Storage (Optional)
# ---------------------------
# S3 Configuration for backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=                          # For S3-compatible services (e.g., MinIO)

# Edge Database (Optional)
# ------------------------
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Monitoring and Analytics (Optional)
# -----------------------------------
SENTRY_DSN=                           # Error tracking
SENTRY_ENVIRONMENT=production
POSTHOG_API_KEY=                      # Product analytics
POSTHOG_HOST=https://app.posthog.com
PLAUSIBLE_DOMAIN=                     # Privacy-friendly analytics

# Performance Monitoring (Optional)
# ---------------------------------
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=${PROJECT_NAME}

# Development Tools (Optional)
# ----------------------------
VITE_DEV_SERVER_PORT=5173
STORYBOOK_PORT=6006
MAILDEV_PORT=1080                     # Email testing UI
MAILDEV_SMTP_PORT=1025                # SMTP port for MailDev
PGADMIN_PORT=5050                     # PostgreSQL admin UI
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
REDIS_INSIGHT_PORT=8001               # Redis admin UI

# Feature Flags (Optional)
# ------------------------
ENABLE_ANALYTICS=false
ENABLE_MONITORING=false
ENABLE_DEBUG_LOGS=false
MAINTENANCE_MODE=false

# Rate Limiting
# -------------
RATE_LIMIT_WINDOW_MS=60000            # 1 minute
RATE_LIMIT_MAX_REQUESTS=100           # Max requests per window

# Session Configuration
# ---------------------
SESSION_COOKIE_NAME=${PROJECT_NAME}_session
SESSION_MAX_AGE=604800                # 7 days in seconds
SESSION_SECURE=true                   # Set to false for local development

# CORS Configuration
# ------------------
CORS_ORIGIN=https://${DOMAIN_NAME}    # Allowed origins (comma-separated)

# Node.js Configuration
# ---------------------
NODE_ENV=production                   # or development
LOG_LEVEL=info                        # debug, info, warn, error

# Next.js Configuration
# ---------------------
NEXT_TELEMETRY_DISABLED=1             # Disable Next.js telemetry
ANALYZE=false                         # Bundle analyzer

# Worker Configuration
# --------------------
WORKER_CONCURRENCY=5                  # Number of concurrent jobs
JOB_TIMEOUT_MS=300000                 # 5 minutes
JOB_ATTEMPTS=3                        # Retry attempts
JOB_BACKOFF_DELAY=60000              # 1 minute

# Security Headers (Optional)
# ---------------------------
HSTS_MAX_AGE=31536000                 # 1 year
CSP_REPORT_URI=