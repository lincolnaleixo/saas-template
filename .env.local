# ================================================
# CONKERO - Environment Configuration
# ================================================
# Copy this file to .env.local for development
# Never commit .env.local or production .env files
# ================================================
# REQUIRED: You MUST set these variables:
# - DB_PASSWORD
# - JWT_SECRET
# ================================================

# Node Environment
NODE_ENV=development                # development | production | test

# ================================================
# Application Settings
# ================================================
APP_NAME=Conkero
APP_VERSION=1.0.0
APP_URL=http://localhost:8000       # Full URL of the application
PROJECT_NAME=conkero               # Used for Docker container naming

# Git Automation (AI Commit Messages)
# -----------------------------------
GROQ_API_KEY=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
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=qwen-qwq-32b
GROQ_TEMPERATURE=0.7
GROQ_TOP_P=0.95
GROQ_MAX_TOKENS=50000
GIT_MAX_RETRIES=3
GIT_RETRY_DELAY_MS=3000

# ================================================
# API Server Configuration
# ================================================
API_PORT=8000
API_HOST=0.0.0.0

# ================================================
# Database Configuration (PostgreSQL)
# ================================================
DATABASE_URL=postgresql://postgres:aksjdh192837189AKJSDHKAJSHD198237@db:5432/conkero
DB_HOST=db
DB_PORT=5432
DB_NAME=conkero
DB_USER=postgres
DB_PASSWORD=aksjdh192837189AKJSDHKAJSHD198237
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=30000              # 30 seconds
DB_CONNECT_TIMEOUT=2000            # 2 seconds

# ================================================
# Redis Configuration
# ================================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis               # Optional if using URL
REDIS_PORT=6379                    # Optional if using URL
REDIS_PASSWORD=                    # Optional

# ================================================
# Authentication & Security
# ================================================
JWT_SECRET=conkero_jwt_secret_key_change_this_in_production_2024
JWT_EXPIRES_IN=7d
SESSION_SECRET=conkero_session_secret_key_change_this_in_production_2024
SESSION_EXPIRES_IN=86400           # 24 hours in seconds

# ================================================
# CORS Configuration
# ================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4001

# ================================================
# Rate Limiting
# ================================================
RATE_LIMIT_WINDOW=900000           # 15 minutes in milliseconds
RATE_LIMIT_MAX=100                 # Max requests per window

# ================================================
# Email Configuration (Optional)
# ================================================
SMTP_HOST=localhost
SMTP_PORT=1025                     # MailDev default port
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@conkero.com

# ================================================
# Worker Configuration
# ================================================
WORKER_PORT=8002

# ================================================
# Development Tools Ports
# ================================================
PGADMIN_PORT=5050
REDIS_INSIGHT_PORT=8001
MAILDEV_PORT=1080
MAILDEV_SMTP_PORT=1025

# ================================================
# Monitoring & Logging
# ================================================
# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Logger Configuration
LOG_TO_FILE=true                    # Enable file logging (backend)
LOG_DIR=./logger                     # Directory for log files (backend)
LOG_MAX_SIZE=10485760               # Max log file size in bytes (10MB)
LOG_MAX_FILES=5                     # Number of log files to keep
LOG_EMOJIS=true                     # Enable emojis in console logs (dev)
LOG_COLORS=true                     # Enable colors in console logs (dev)

# Remote Logging (frontend)
REMOTE_LOG_ENDPOINT=                # Endpoint for remote logging
REMOTE_LOG_API_KEY=                 # API key for remote logging

# ================================================
# Production-Only Settings
# ================================================
# SSL/HTTPS (handled by nginx in production)
# DOMAIN_NAME=conkero.com
# SSL_EMAIL=admin@conkero.com

# ================================================
# Docker Network Settings
# ================================================
# All ports can be customized for multiple deployments
# DB_PORT=5432
# REDIS_PORT=6379
# API_PORT=8000
# WORKER_PORT=8002
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443