FROM oven/bun:1-alpine

WORKDIR /app

# Copy package files
COPY package.json ./
COPY bun.lockb* ./

# Install dependencies
RUN bun install

# Copy frontend source code and config
COPY frontend ./frontend
COPY vite.config.js ./

# Expose port (configurable via environment)
EXPOSE ${PORT:-4001}

# Run dev server
CMD ["bun", "run", "vite", "--host", "0.0.0.0", "--port", "${PORT:-4001}"]